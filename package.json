{
  "name": "react-native-app-inspector",
  "version": "0.2.0",
  "description": "On-device performance & debug panel for React Native — no Metro, no USB, no computer.",
  "main": "./lib/commonjs/index.js",
  "module": "./lib/module/index.js",
  "types": "./lib/typescript/commonjs/src/index.d.ts",
  "react-native": "./src/index.ts",
  "source": "./src/index.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./lib/typescript/module/src/index.d.ts",
        "default": "./lib/module/index.js"
      },
      "require": {
        "types": "./lib/typescript/commonjs/src/index.d.ts",
        "default": "./lib/commonjs/index.js"
      }
    }
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "react-native-app-inspector.podspec",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/*.test.ts",
    "!**/*.test.tsx",
    "!android/build",
    "!android/.gradle",
    "!ios/build",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bob build",
    "prepare": "bob build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"{src,__tests__}/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"{src,__tests__}/**/*.{ts,tsx}\" --fix",
    "format": "prettier --write \"{src,__tests__}/**/*.{ts,tsx,json,md}\"",
    "test": "jest"
  },
  "keywords": [
    "react-native",
    "ios",
    "android",
    "debug",
    "debugging",
    "inspector",
    "devtools",
    "network-logger",
    "qa",
    "staging"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phaelor/react-native-app-inspector.git"
  },
  "author": "phaelor <phaelor@mail.ru>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/phaelor/react-native-app-inspector/issues"
  },
  "homepage": "https://github.com/phaelor/react-native-app-inspector#readme",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.72.0"
  },
  "devDependencies": {
    "@react-native/babel-preset": "0.74.87",
    "@testing-library/react-native": "^12.5.2",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.2.79",
    "@types/react-test-renderer": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "babel-jest": "^29.7.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-builder-bob": "^0.30.3",
    "react-test-renderer": "18.2.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.4.5"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "commonjs",
        {
          "esm": true
        }
      ],
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "esm": true
        }
      ]
    ]
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
